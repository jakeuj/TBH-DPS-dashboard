---
import { type Locale, GITHUB_OWNER, GITHUB_REPO } from '../config';
import { getDict } from '../i18n';
import Screenshot from './Screenshot.astro';
import hero from '../assets/hero.jpg';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = getDict(locale).hero;
const releases = `https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}/releases/latest`;
const gh = `https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}`;
---
<header class="hero"><div class="wrap">
  <div class="eyebrow">{t.eyebrow}</div>
  <h1>{t.titleA} <span class="grad">{t.titleHighlight}</span></h1>
  <p class="lede">{t.lede}</p>
  <div class="cta">
    <a class="btn primary" href={releases}>↓ {t.ctaDownload}</a>
    <a class="btn ghost" href={gh}>{t.ctaGithub}</a>
  </div>
  <div class="trustline">
    <span>⭐ <b>{t.trust.mit}</b></span>
    <span>👁 <b>{t.trust.readonly}</b></span>
    <span>🌐 <b>{t.trust.langs}</b></span>
    <span>✅ <b>{t.trust.tested}</b></span>
  </div>
  <div class="hero-shot"><Screenshot src={hero} alt="TBH DPS Meter in-game overlay" /></div>
</div></header>
