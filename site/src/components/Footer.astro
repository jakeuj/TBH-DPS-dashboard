---
import { type Locale, GITHUB_OWNER, GITHUB_REPO } from '../config';
import { localizedPath } from '../lib/seo';
import { getDict } from '../i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const dict = getDict(locale);
const t = dict.footer;
const gh = `https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}`;
---
<footer><div class="wrap">
  <div class="row">
    <a class="logo" href={localizedPath(locale, '/')}><span class="mk">⚔</span> TBH DPS Meter</a>
    <span class="spacer"></span>
    <a href={gh}>GitHub</a>
    <a href={`${gh}/blob/main/LICENSE`}>{t.license}</a>
    <a href={localizedPath(locale, '/changelog')}>{dict.changelog.title}</a>
  </div>
  <p style="margin-top:14px;font-size:12px;color:#9aa4b2">{t.disclaimerLong}</p>
</div></footer>
