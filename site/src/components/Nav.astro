---
import { type Locale, GITHUB_OWNER, GITHUB_REPO } from '../config';
import { localizedPath } from '../lib/seo';
import { getDict } from '../i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';
interface Props { locale: Locale; path: string; }
const { locale, path } = Astro.props;
const t = getDict(locale).nav;
const home = localizedPath(locale, '/');
const releases = `https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}/releases/latest`;
---
<nav><div class="wrap row">
  <a class="logo" href={home}><span class="mk">⚔</span> TBH DPS Meter</a>
  <a class="lnk" href={`${home}#features`}>{t.features}</a>
  <a class="lnk" href={localizedPath(locale, '/install')}>{t.install}</a>
  <a class="lnk" href={`${home}#faq`}>{t.faq}</a>
  <span class="spacer"></span>
  <LanguageSwitcher locale={locale} path={path} />
  <a class="btn primary" href={releases}>{t.download}</a>
</div></nav>
