---
import { type Locale } from '../config';
import { localizedPath } from '../lib/seo';
import { getDict } from '../i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = getDict(locale).install;
---
<section class="section" id="install"><div class="wrap">
  <div class="kicker">{t.kicker}</div>
  <div class="h2">{t.title}</div>
  <p class="sub">{t.sub}</p>
  <div class="steps">
    {t.steps.map((s, i) => (
      <div class="step"><div class="num">{i + 1}</div><h4>{s.title}</h4><p>{s.body}</p></div>
    ))}
  </div>
  <p style="text-align:center;margin-top:28px"><a class="btn ghost" href={localizedPath(locale, '/install')}>{t.full}</a></p>
</div></section>
