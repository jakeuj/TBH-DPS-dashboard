---
import BaseLayout from '../components/BaseLayout.astro';
import { getDict } from '../i18n';
import { localizedPath } from '../lib/seo';
const locale = 'en' as const;
const dict = getDict(locale);
const t = dict.installPage;
---
<BaseLayout locale={locale} path="/install" title={dict.meta.installTitle} description={dict.meta.installDesc}>
  <section class="section"><div class="wrap" style="max-width:780px">
    <div class="kicker" style="text-align:left">{dict.nav.install}</div>
    <h1 style="font-size:40px;line-height:1.1;letter-spacing:-1px;margin:8px 0 10px">{dict.meta.installTitle}</h1>
    <p class="lede" style="margin:0 0 36px;text-align:left">{t.lead}</p>

    <h2 style="font-size:24px;margin:0 0 14px">{t.firstTime.title}</h2>
    <ol style="padding-left:20px;display:flex;flex-direction:column;gap:10px;color:var(--muted)">
      {t.firstTime.steps.map((s) => <li>{s}</li>)}
    </ol>

    <h2 style="font-size:24px;margin:36px 0 12px">{t.update.title}</h2>
    <p style="color:var(--muted)">{t.update.body}</p>

    <h2 style="font-size:24px;margin:36px 0 12px">{t.blackScreen.title}</h2>
    <p style="color:var(--muted)">{t.blackScreen.body}</p>

    <h2 style="font-size:24px;margin:36px 0 12px">{t.uninstall.title}</h2>
    <p style="color:var(--muted)">{t.uninstall.body}</p>

    <p style="margin-top:40px"><a class="btn ghost" href={localizedPath(locale, '/')}>{t.backHome}</a></p>
  </div></section>
</BaseLayout>
